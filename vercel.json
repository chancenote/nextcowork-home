{
  "outputDirectory": ".",
  "trailingSlash": true,
  "redirects": [
    { "source": "/workplace_consulting", "destination": "/flexoffice/", "permanent": true },
    { "source": "/workplace_consulting/", "destination": "/flexoffice/", "permanent": true },
    { "source": "/ceo_ai", "destination": "/coaching/", "permanent": true },
    { "source": "/ceo_ai/", "destination": "/coaching/", "permanent": true },
    { "source": "/:id([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})", "destination": "/insights/", "permanent": true },
    { "source": "/:id([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{4}-[0-9a-fA-F]{12})/", "destination": "/insights/", "permanent": true },
    { "source": "/:id([0-9a-fA-F]{32})", "destination": "/insights/", "permanent": true },
    { "source": "/:id([0-9a-fA-F]{32})/", "destination": "/insights/", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=86400" }]
    },
    {
      "source": "/js/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    }
  ]
}
